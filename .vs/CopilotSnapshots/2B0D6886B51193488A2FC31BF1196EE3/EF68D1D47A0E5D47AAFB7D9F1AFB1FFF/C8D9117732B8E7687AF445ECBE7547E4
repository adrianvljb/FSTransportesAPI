using System;
using FSTransportesAPI.Common;
using FSTransportesAPI.Data;
using FSTransportesAPI.Entities.DTOs;
using FSTransportesAPI.Entities.Models;
using Microsoft.EntityFrameworkCore;

namespace FSTransportesAPI.Business
{
    public class ViajeService
    {
        private readonly FSTransportesContext _context;
        private readonly ViajeDomainService _domainService;

        public ViajeService(FSTransportesContext context, ViajeDomainService domainService)
        {
            _context = context;
            _domainService = domainService;
        }

        public async Task<string> ValidarYRegistrarViaje(RegistrarViajeRequestDto dto)
        {

            //agregar trycatch y validaciones
            //Se agrego el trycatch y se aislo la logica de validacion y registro en un solo metodo para evitar codigo repetido y mejorar la mantenibilidad del codigo
            try
            {
                var usuario = await _context.Usuarios.FindAsync(dto.IdUsuarioRegistro);

                string validacion = _domainService.ValidarReglasNegocio(usuario, dto);

                if (!string.IsNullOrEmpty(validacion))
                {
                    return validacion;
                }

                foreach (var detalle in dto.Detalles)
                {
                    bool yaViajoHoy = await _context.ViajesDetalles
                        .Include(vd => vd.Viaje)
                        .AnyAsync(vd => vd.IdColaborador == detalle.IdColaborador
                                     && vd.Viaje.FechaViaje.Date == dto.FechaViaje.Date);

                    if (yaViajoHoy)
                    {
                        return Mensajes.ErrorColaboradorYaViajoHoy;
                    }
                }

                var nuevoViaje = new Viaje
                {
                    FechaViaje = dto.FechaViaje,
                    IdSucursal = dto.IdSucursal,
                    IdTransportista = dto.IdTransportista,
                    IdUsuarioRegistro = dto.IdUsuarioRegistro,
                    Detalles = dto.Detalles.Select(d => new ViajeDetalle
                    {
                        IdColaborador = d.IdColaborador,
                        DistanciaKilometros = d.DistanciaKilometros,
                        TarifaSugerida = d.TarifaSugerida
                    }).ToList()
                };

                _context.Viajes.Add(nuevoViaje);
                int filasAfectadas = await _context.SaveChangesAsync();

                return filasAfectadas > 0 ? Mensajes.RegistroExitoso : Mensajes.ErrorInesperado;
            }
            catch (Exception)
            {
                return Mensajes.ErrorInesperado;
            }
        }



    }
}



