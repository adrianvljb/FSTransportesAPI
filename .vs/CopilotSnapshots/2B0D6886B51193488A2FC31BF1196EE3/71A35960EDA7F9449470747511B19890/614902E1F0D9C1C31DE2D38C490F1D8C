using Microsoft.EntityFrameworkCore;
using FSTransportesAPI.Infrastructure.SQLServer;
using FSTransportesAPI.Features.Transportistas.Dtos;

namespace FSTransportesAPI.Features.Transportistas.Services
{
    public class ReporteViajeTransportistaService
    {
        private readonly FSTransportesDbContext _context;

        public ReporteViajeTransportistaService(FSTransportesDbContext context)
        {
            _context = context;
        }

        public async Task<List<ReporteTransportistaDto>> ObtenerResumenViajes(DateTime inicio, DateTime fin)
        {
            return await _context.Viajes
                .AsNoTracking() 
                .Where(v => v.FechaViaje >= inicio && v.FechaViaje <= fin)
                .Select(v => new ReporteTransportistaDto
                {
                    IdViaje = v.IdViaje,
                    Fecha = v.FechaViaje,
                    Sucursal = v.Sucursal.Nombre,
                    Transportista = v.Transportista.Nombre,
                    TotalKM = v.Detalles.Sum(d => d.DistanciaKilometros),
                    TotalPagarTransporte = v.Detalles.Sum(d => d.DistanciaKilometros) * v.Transportista.TarifaPorKM
                })
                .ToListAsync();
        }
    }
}