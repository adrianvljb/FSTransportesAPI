using FSTransportesAPI.Business;
using FSTransportesAPI.Common;
using FSTransportesAPI.Entities.DTOs;
using Microsoft.AspNetCore.Mvc;

namespace FSTransportesAPI.WebApi.Controllers
{
    [Route("api/[controller]")]
    [ApiController]
    public class ViajeController : ControllerBase
    {
        private readonly ViajeService _viajeService;

        public ViajeController(ViajeService viajeService)
        {
            _viajeService = viajeService;
        }

        [HttpPost("RegistrarViaje")]
        public async Task<IActionResult> RegistrarViaje([FromBody] RegistrarViajeRequestDto dto)
        {
            var resultado = await _viajeService.ValidarYRegistrarViaje(dto);
            if (resultado == Mensajes.RegistroExitoso)
            {
                return Ok(new { mensaje = resultado });
            }

            return BadRequest(new { error = resultado });
        }
    }
}
